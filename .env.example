# --- Database (PostgreSQL via Neon or Supabase) ---
# Neon: copy the "Pooled connection" string and keep ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Better Auth ---
# Generate a secret:  openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL used by the browser auth client
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Groq (optional — enables AI analysis of accusations) ---
# Free API key at: https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
